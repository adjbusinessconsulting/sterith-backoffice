generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Existing POS tables ──────────────────────────────────────────────────────
// DO NOT drop or rename existing columns — only additions via migration.

// stores.owner_id → auth.users.id (Supabase Auth manages owner credentials)
model Store {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  address   String?
  phone     String?
  ownerId   String    @map("owner_id") @db.Uuid
  tier      String    @default("FREE")
  status    String    @default("active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  // Added by Backoffice migration
  clientCode String?   @unique @map("client_code")
  syncedAt   DateTime? @map("synced_at") @db.Timestamptz(6)

  products       Product[]
  sales          Sale[]
  cashiers       Cashier[]
  shifts         Shift[]
  stockMovements StockMovement[]
  opnames        Opname[]
  cashDrawers    CashDrawer[]
  activityLogs   ActivityLog[]

  @@map("stores")
}

// products.id is text in the existing POS (not UUID)
model Product {
  id          String   @id
  storeId     String   @map("store_id") @db.Uuid
  store       Store    @relation(fields: [storeId], references: [id])
  name        String
  monogram    String?
  emoji       String?
  category    String
  unit        String
  price       Int
  stock       Int      @default(0)  // POS field — kept for POS compat
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Added by Backoffice migration
  sku          String?
  threshold    Int      @default(10)
  warehouseQty Int      @default(0) @map("warehouse_qty")
  storeQty     Int      @default(0) @map("store_qty")
  soldToday    Int      @default(0) @map("sold_today")
  photoUrl     String?  @map("photo_url")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  saleItems  SaleItem[]
  movements  StockMovement[]

  @@map("products")
}

model Sale {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId       String   @map("store_id") @db.Uuid
  store         Store    @relation(fields: [storeId], references: [id])
  trxId         String   @map("trx_id")
  cashierId     String   @map("cashier_id")
  cashierName   String   @map("cashier_name")
  shift         Int?
  total         Int
  paymentMethod String   @map("payment_method")
  cashReceived  Int?     @map("cash_received")
  changeAmount  Int?     @map("change_amount")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  items SaleItem[]

  @@map("sales")
}

model SaleItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId      String  @map("sale_id") @db.Uuid
  sale        Sale    @relation(fields: [saleId], references: [id])
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  productName String  @map("product_name")
  price       Int
  qty         Int
  subtotal    Int

  @@map("sale_items")
}

model Cashier {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  store     Store    @relation(fields: [storeId], references: [id])
  name      String?
  initials  String
  role      String   @default("kasir")  // kasir | manajer
  pin       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("cashiers")
}

// ─── New Backoffice tables ────────────────────────────────────────────────────

model Shift {
  id                String  @id @default(cuid())
  storeId           String  @map("store_id") @db.Uuid
  store             Store   @relation(fields: [storeId], references: [id])
  name              String
  startTime         String  @map("start_time")
  endTime           String  @map("end_time")
  assignedCashierId String? @map("assigned_cashier_id")

  @@map("shifts")
}

// type: MASUK | TRANSFER | TERJUAL | RUSAK | OPNAME
// fromLoc / toLoc: WAREHOUSE | STORE
model StockMovement {
  id        String   @id @default(cuid())
  storeId   String   @map("store_id") @db.Uuid
  store     Store    @relation(fields: [storeId], references: [id])
  type      String
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  qty       Int
  fromLoc   String?  @map("from_loc")
  toLoc     String?  @map("to_loc")
  byUserId  String   @map("by_user_id")  // auth.users UUID or cashier id
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("stock_movements")
}

// status: DRAFT | PENDING | APPROVED
// location: WAREHOUSE | STORE
model Opname {
  id           String      @id @default(cuid())
  storeId      String      @map("store_id") @db.Uuid
  store        Store       @relation(fields: [storeId], references: [id])
  location     String
  status       String      @default("DRAFT")
  createdById  String      @map("created_by_id")
  approvedById String?     @map("approved_by_id")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  approvedAt   DateTime?   @map("approved_at") @db.Timestamptz(6)
  lines        OpnameLine[]

  @@map("opnames")
}

model OpnameLine {
  id          String @id @default(cuid())
  opnameId    String @map("opname_id")
  opname      Opname @relation(fields: [opnameId], references: [id])
  productId   String @map("product_id")
  systemQty   Int    @map("system_qty")
  physicalQty Int    @map("physical_qty")

  @@map("opname_lines")
}

// entryType: OPEN | IN | OUT | AUTO_SALES | CLOSE
model CashDrawer {
  id        String   @id @default(cuid())
  storeId   String   @map("store_id") @db.Uuid
  store     Store    @relation(fields: [storeId], references: [id])
  entryType String   @map("entry_type")
  amount    Int
  note      String?
  byUserId  String   @map("by_user_id")
  shiftId   String?  @map("shift_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("cash_drawers")
}

// Master Office activity timeline
model ActivityLog {
  id        String   @id @default(cuid())
  storeId   String   @map("store_id") @db.Uuid
  store     Store    @relation(fields: [storeId], references: [id])
  type      String
  byUserId  String?  @map("by_user_id")
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("activity_logs")
}
